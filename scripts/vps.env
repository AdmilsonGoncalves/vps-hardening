# ==============================================================================
# File Name    : vps.env
# Description  : Centralized Configuration Parameters for VPS Hardening Suite
#                All scripts automatically source this file (if present) to
#                establish baseline defaults across stages.
#                Command-line arguments or exported environment variables
#                will always take precedence over values defined here.
# ==============================================================================

# Target administrative username to provision and grant sudo escalation privileges.
# (Best practice: Avoid 'root' or common dictionary names like 'admin' or 'test')
ADMIN_USER="vpsadmin"

# Direct public SSH key string to inject into the administrative user's authorized_keys.
# (If set, takes precedence over PUBKEY_SOURCE. Example: "ssh-ed25519 AAAAC3N... user@workstation")
ADMIN_USER_PUBKEY=""

# Source path for public SSH keys to inject into the administrative user's authorized_keys.
# (Defaults to root's authorized_keys if initial deployment used root SSH keys)
PUBKEY_SOURCE="/root/.ssh/authorized_keys"

# Obfuscated SSH listening port for OpenSSH daemon and systemd socket overrides.
# (REQUIRED: You must specify your preferred non-standard SSH port between 1024 - 65535 before running Stage 2)
SSH_PORT="" # e.g. "your-preferred-ssh-port"

# Additional TCP/UDP ports or services to whitelist in UFW alongside SSH_PORT.
# (Format: space-separated list of ports/protocols. Example: "80/tcp 443/tcp 8080/tcp". Leave empty or "" if only SSH is required)
UFW_ALLOWED_PORTS="80/tcp 443/tcp"

# System Timezone to configure via timedatectl (e.g. "America/Sao_Paulo", "UTC", "Europe/London").
# (If left empty, preserves existing system timezone or cloud provider default)
TIMEZONE="America/Sao_Paulo"

# Scheduled local time for controlled maintenance reboots when kernel/system updates flag reboot-required.
# (Format: "HH:MM" in 24-hour format matching the server's configured timezone above. Defaults to "04:30")
REBOOT_TIME="04:30"
